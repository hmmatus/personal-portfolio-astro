---
export type Props = {
  projectsList: ProjectI[];
};
import type { ProjectI } from "src/types/project";
import { ProjectsCarousel } from "./ProjectsCarousel";
import styles from "./ProjectsSection.module.scss";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const { projectsList } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class={styles["projects-section-container"]} id="projects" data-reveal>
  <div class="section-label">04 — Projects</div>
  <h2>{t("projects.title")}</h2>
  <p>
    {t("projects.description")}
  </p>
  <ProjectsCarousel
    client:visible
    projectsList={projectsList}
    lang={lang}
  />
</section>
