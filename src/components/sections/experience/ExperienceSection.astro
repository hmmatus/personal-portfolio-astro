---
import { ExperienceCarousel } from "./ExperienceCarousel";
import styles from "./ExperienceSection.module.scss";
import type { ExperienceI } from "src/types/experience";
import { useTranslations } from "../../../i18n/utils";
import { EXPERIENCE_I18N_KEYS } from "./ExperienceSection.const";

export interface Props {
  experienceList: ExperienceI[];
}

const { experienceList } = Astro.props;
const lang = Astro.locals.lang;
const t = useTranslations(lang);
---

<section id="skills-section" class={styles.container} data-reveal>
  <div class="section-label">03 — Experience</div>
  <h2>{t(EXPERIENCE_I18N_KEYS.TITLE).toUpperCase()}</h2>
  <ExperienceCarousel
    client:visible
    experienceList={experienceList}
    lang={lang}
  />
</section>
